{
  "name": "agentfoundry",
  "version": "0.1.0",
  "description": "CLI-first AI task manager with planning, queueing, dispatch, and verification.",
  "type": "module",
  "bin": {
    "agentfoundry": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli/index.ts",
    "dashboard:dev": "vite --config dashboard-ui/vite.config.ts",
    "dashboard:build": "vite build --config dashboard-ui/vite.config.ts",
    "plan": "tsx src/cli/index.ts plan",
    "run": "tsx src/cli/index.ts run",
    "mcp-run": "tsx src/cli/index.ts mcp-run",
    "mcp-server": "tsx src/cli/index.ts mcp-server",
    "dashboard": "tsx src/cli/index.ts dashboard",
    "status": "tsx src/cli/index.ts status",
    "watch": "tsx src/cli/index.ts watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "npx dep-pulse || true"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.0",
    "better-sqlite3": "^11.8.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^0.525.0",
    "radix-vue": "^1.9.13",
    "tailwind-merge": "^2.6.0",
    "vue": "^3.5.13",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.8",
    "@vitejs/plugin-vue": "^5.2.1",
    "tailwindcss": "^4.1.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.8",
    "dep-pulse": "^1.0.1"
  }
}
