{
  "mcpServers": {
    "agentfoundry": {
      "command": "node",
      "args": ["dist/cli/index.js", "mcp-server"],
      "cwd": "/absolute/path/to/do-agi",
      "env": {
        "AGENTFOUNDRY_DB_PATH": "./agentfoundry.db",
        "AGENTFOUNDRY_SUBAGENT_CMD": "/absolute/path/to/subagent-runner.sh"
      }
    }
  },
  "routing": {
    "useAgentFoundryWhen": [
      "request has multiple deliverables",
      "request implies sequencing or dependencies",
      "request requires explicit verification checkpoints"
    ],
    "otherwise": "handle directly in main agent"
  }
}